# Copy this file to `.env` and fill in your key. `.env` is git-ignored — never commit it.
# The deliberative process reads ANTHROPIC_API_KEY from the environment (or this .env).

ANTHROPIC_API_KEY=

# Model routing tiers (see docs/technical/software-spec.md §3). Override here if needed.
YALP_MODEL_FAST=claude-haiku-4-5
YALP_MODEL_MID=claude-sonnet-4-6
YALP_MODEL_BIG=claude-opus-4-8

# Voice input (STT) configuration
YALP_VOICE_SOURCE=microphone        # Audio source: 'microphone' (live capture) | 'file' (WAV) | 'synthetic' (tests)
YALP_VOICE_SAMPLE_RATE=16000        # PCM sample rate in Hz (16000 recommended for Whisper)
YALP_VOICE_CHANNELS=1               # Audio channels: 1 = mono, 2 = stereo (Whisper expects mono)
YALP_VOICE_RECORD_SECONDS=5         # Seconds of audio to capture per utterance (microphone mode)
YALP_VOICE_AUDIO_FILE=              # Path to WAV file used when YALP_VOICE_SOURCE=file
YALP_STT_BACKEND=faster-whisper     # STT backend: 'faster-whisper' for local inference | 'fake' for tests
YALP_STT_MODEL=tiny                 # Whisper model size: tiny|base (trade speed vs accuracy)
