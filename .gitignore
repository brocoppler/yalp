# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
.venv/
venv/

# --- Secrets & credentials (NEVER commit real values) ---
# Local env files hold the live ANTHROPIC_API_KEY and other secrets.
.env
.env.*
# ...but keep the committed, value-free template:
!.env.example
# TLS certs / private keys / SSH material.
*.pem
*.key
*.p12
*.pfx
*.ppk
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
known_hosts
# Ad-hoc credential drops (e.g. host password files kept outside the repo).
ssh-izzy*

# --- Captured media (camera/VLM stills) ---
captures/
*.jpg
*.png
# ...but keep the committed test asset:
!tests/assets/sample.jpg
# ...and keep documentation blueprint illustrations:
!docs/images/*.png

# --- Detector model weights (downloaded once + cached, never committed) ---
# The cv2.dnn person detector (MobileNet-SSD) caches its model files under
# models/ or ~/.cache/yalp/models. Never commit the binaries.
models/
*.caffemodel
*.onnx
*.prototxt
*.pb
*.weights

# --- OS / editor cruft ---
.DS_Store
