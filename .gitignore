# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
.venv/
venv/

# --- Secrets ---
.env

# --- Captured media (camera/VLM stills) ---
captures/
*.jpg
*.png
# ...but keep the committed test asset:
!tests/assets/sample.jpg
# ...and keep documentation blueprint illustrations:
!docs/images/*.png

# --- Detector model weights (downloaded once + cached, never committed) ---
# The cv2.dnn person detector (MobileNet-SSD) caches its model files under
# models/ or ~/.cache/yalp/models. Never commit the binaries.
models/
*.caffemodel
*.onnx
*.prototxt
*.pb
*.weights

# --- OS / editor cruft ---
.DS_Store
